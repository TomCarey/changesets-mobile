{
  "name": "changesets-mobile",
  "version": "0.0.1",
  "description": "Changeset wrapper with iOS and Android native version management",
  "type": "module",
  "bin": {
    "changeset-mobile": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "keywords": [
    "changesets",
    "ios",
    "android",
    "mobile",
    "versioning",
    "react-native"
  ],
  "author": "Tom Carey",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/TomCarey/changesets-mobile.git"
  },
  "homepage": "https://github.com/TomCarey/changesets-mobile#readme",
  "bugs": {
    "url": "https://github.com/TomCarey/changesets-mobile/issues"
  },
  "dependencies": {
    "@changesets/cli": "^2.27.0",
    "execa": "^9.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
